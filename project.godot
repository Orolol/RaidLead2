; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="RaidLead"
config/description="Un jeu de gestion de guilde dans un MMORPG fictif"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameTime="*res://scripts/autoloads/game_time.gd"
ServerVersion="*res://scripts/autoloads/server_version.gd"
EffectSystem="*res://scripts/systems/effect_system.gd"
ActivityManager="*res://scripts/systems/activity_manager.gd"
GuildManager="*res://scripts/autoloads/guild_manager.gd"
RecruitmentPool="*res://scripts/autoloads/recruitment_pool.gd"
EventManager="*res://scripts/autoloads/event_manager.gd"
PhaseManager="*res://scripts/systems/phase_manager.gd"
GuildRanking="*res://scripts/systems/guild_ranking.gd"
AIGuildManager="*res://scripts/systems/ai_guild_manager.gd"
MediaManager="*res://scripts/systems/media_manager.gd"
SponsorshipManager="*res://scripts/systems/sponsorship_manager.gd"
DramaManager="*res://scripts/systems/drama_manager.gd"
StaffManager="*res://scripts/systems/staff_manager.gd"
TournamentManager="*res://scripts/systems/tournament_manager.gd"
TransferManager="*res://scripts/systems/transfer_manager.gd"
LegacyManager="*res://scripts/systems/legacy_manager.gd"
NotificationManager="*res://scripts/managers/notification_manager.gd"
SaveManager="*res://scripts/autoloads/save_manager.gd"
AssetLoader="*res://scripts/autoloads/asset_loader.gd"
GuildCultureManager="*res://scripts/systems/guild_culture_manager.gd"
AdvisorManager="*res://scripts/systems/advisor_manager.gd"
BalanceManager="*res://scripts/systems/balance_manager.gd"
ChatDirector="*res://scripts/systems/chat_director.gd"
MCPScreenshot="*res://addons/godot_mcp/mcp_screenshot_service.gd"
MCPInputService="*res://addons/godot_mcp/mcp_input_service.gd"
MCPGameInspector="*res://addons/godot_mcp/mcp_game_inspector_service.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/resizable=false

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_mcp/plugin.cfg")

[rendering]

renderer/rendering_method="mobile"
